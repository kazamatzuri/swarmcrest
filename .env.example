# SwarmCrest Production Environment Variables
# Copy this file to .env and fill in the values before deploying.

# ── Required ────────────────────────────────────────────────────────

# Secret key for signing JWT tokens. Generate with:
#   openssl rand -base64 32
JWT_SECRET=

# PostgreSQL password. Generate with:
#   openssl rand -base64 24
POSTGRES_PASSWORD=

# ── Optional (have sensible defaults) ───────────────────────────────

# Domain name (used in ALLOWED_ORIGINS and Caddy TLS)
# DOMAIN=swarmcrest.submerged-intelligence.de

# PostgreSQL user and database name
# POSTGRES_USER=swarmcrest
# POSTGRES_DB=swarmcrest

# Number of parallel headless game workers
# SWARMCREST_WORKER_COUNT=4

# Queue polling interval in milliseconds
# SWARMCREST_QUEUE_POLL_MS=1000

# Log level (trace, debug, info, warn, error)
# RUST_LOG=info

# Bearer token to protect /metrics endpoint.
# Leave unset to allow public access (not recommended in production).
# METRICS_TOKEN=

# Grafana admin password (only needed with monitoring profile)
# GRAFANA_ADMIN_PASSWORD=
