#!/bin/bash
# Pre-commit hook: check Rust formatting and frontend linting

# Check if any backend files are staged
if git diff --cached --name-only | grep -q '^backend/'; then
    echo "Checking Rust formatting..."
    if ! cargo fmt --manifest-path backend/Cargo.toml -- --check 2>/dev/null; then
        echo ""
        echo "ERROR: Rust formatting check failed."
        echo "Run 'cargo fmt --manifest-path backend/Cargo.toml' to fix."
        exit 1
    fi
fi

# Check if any frontend files are staged
if git diff --cached --name-only | grep -q '^frontend/'; then
    if [ -f frontend/node_modules/.bin/eslint ]; then
        echo "Checking frontend lint..."
        STAGED_JS=$(git diff --cached --name-only --diff-filter=d | grep '^frontend/src/.*\.\(ts\|tsx\|js\|jsx\)$' || true)
        if [ -n "$STAGED_JS" ]; then
            if ! npx --prefix frontend eslint $STAGED_JS 2>/dev/null; then
                echo ""
                echo "ERROR: ESLint check failed."
                echo "Run 'cd frontend && npx eslint --fix <files>' to fix."
                exit 1
            fi
        fi
    fi
fi
